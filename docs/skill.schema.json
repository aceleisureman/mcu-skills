{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/georgesven/skills/docs/skill.schema.json",
  "title": "Skill 元数据 (skill.json)",
  "type": "object",
  "required": [
    "schema_version",
    "name",
    "version",
    "title",
    "summary",
    "layer",
    "dependencies",
    "triggers",
    "routes"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": 1,
      "description": "元数据格式版本"
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "Skill 名称，必须与目录名一致"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "SemVer 版本号，与 CHANGELOG.md 当前条目一致"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "人类可读标题"
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "description": "一句话职责描述"
    },
    "layer": {
      "enum": ["foundation", "domain", "orchestrator", "utility"],
      "description": "架构层级"
    },
    "license": {
      "type": "string",
      "minLength": 1,
      "description": "SPDX 许可证标识，如 MIT"
    },
    "author": {
      "type": "string",
      "minLength": 1,
      "description": "作者或维护者"
    },
    "platforms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": ["claude-code", "codex", "codebuddy"]
      },
      "description": "已验证可用的 Agent 平台"
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
      },
      "description": "直接依赖的 Skill 名称"
    },
    "triggers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Skill 级触发词"
    },
    "routes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "intent", "keywords", "target"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
          },
          "intent": {
            "type": "string",
            "minLength": 1
          },
          "keywords": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "target": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "description": "Skill 内资源路由"
    }
  }
}
