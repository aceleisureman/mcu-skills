# 复制为 server/.env 或导出到环境

# 仓库根（含 skills/ tools/）
MCU_SKILLS_ROOT=.

# 上传与 BM25 快照目录
MCU_DATA_DIR=./data

# MySQL（推荐完整 URL）
MCU_DATABASE_URL=mysql+aiomysql://mcu_skills:change-me@127.0.0.1:3306/mcu_skills?charset=utf8mb4

# 或分项拼装（URL 为空时生效）
# MCU_DB_HOST=127.0.0.1
# MCU_DB_PORT=3306
# MCU_DB_USER=mcu_skills
# MCU_DB_PASSWORD=change-me
# MCU_DB_NAME=mcu_skills

# 首次启动写入 admin key（key_id.secret）；留空则自动生成并打日志
# MCU_BOOTSTRAP_ADMIN_KEY=

# 每天 02:00 重建索引
MCU_REINDEX_CRON=0 2 * * *

# organize 可扫描/写入的项目根（逗号分隔）；默认仅 skills 仓库根
# MCU_WORKSPACE_ALLOWLIST=/data/projects

MCU_HOST=0.0.0.0
MCU_PORT=8080
MCU_SESSION_SECRET=change-me-in-production
